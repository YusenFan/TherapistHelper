# TherapistHelper Backend Environment Variables

# =============================================================================
# Appwrite Configuration
# =============================================================================
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your-project-id-here
APPWRITE_API_KEY=your-api-key-here
APPWRITE_DATABASE_ID=therapist_helper

# =============================================================================
# OpenAI Configuration (for Whisper Transcription)
# =============================================================================
OPENAI_API_KEY=sk-your-openai-api-key-here

# =============================================================================
# Tinfoil.sh API Configuration (for LLM - Confidential Client Data)
# =============================================================================
TINFOIL_API_KEY=tk_UfPWya5M50awLMxcp9jjNlF8lBBFtxst0L4gqu6104uGmnxY

# =============================================================================
# Deepgram (multilingual speech-to-text for session voice input)
# =============================================================================
DEEPGRAM_API_KEY=your-deepgram-api-key-here
DEEPGRAM_MODEL=nova-3

# =============================================================================
# Security Configuration
# =============================================================================
SECRET_KEY=your-secret-key-change-in-production-use-a-long-random-string
ENCRYPTION_KEY=your-encryption-key-change-in-production-generate-new-one

# =============================================================================
# Environment
# =============================================================================
ENVIRONMENT=development
DEBUG=true

# =============================================================================
# Frontend URL (for CORS)
# =============================================================================
NEXT_PUBLIC_API_URL=http://localhost:8000
